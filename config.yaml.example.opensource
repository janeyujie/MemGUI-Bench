# ==============================================================================
# MemGUI-Bench Configuration Example
# ==============================================================================
# Configuration Structure:
#   - Part 1-4: Parameters to check/adjust for each experiment
#   - Part 5-7: Fixed configurations, generally no modification needed
#
# Quick Start:
#   1. Copy this file as config.yaml
#   2. Set the mode in Part 1
#   3. Set experiment parameters in Part 2 (DATASET_PATH, SESSION_ID_SUFFIX)
#   4. Configure API settings in Part 3 (BASE_URL, NUM_OF_EMULATOR, etc.)
#   5. Run: python run.py
# ==============================================================================

# ==============================================================================
# Part 1: Mode Selection (Check before each experiment)
# ==============================================================================
# Environment mode: "docker" (Docker environment) | "local" (local environment)
#   - docker: Use Docker container paths (/root/...)
#   - local: Use local development environment paths
ENVIRONMENT_MODE: "local"

# ==============================================================================
# Part 2: Experiment Settings (Must configure for each experiment)
# ==============================================================================
# Agent name
AGENT_NAME: "Qwen3VL"

# Dataset path (must be specified, no default)
DATASET_PATH: "./data/memgui-tasks-all.csv"

# Session ID suffix (only specify the suffix part)
# Prefix "memgui-" is automatically added
# Example: Set to "v25122902-qwen8b-test" -> "memgui-v25122902-qwen8b-test"
SESSION_ID_SUFFIX: "v25122902-debug"

# ==============================================================================
# Part 3: API and Parallelism Settings (Adjust as needed)
# ==============================================================================
# API Base URL for all models
BASE_URL: "https://openrouter.fans/v1"

# Parallelism settings
NUM_OF_EMULATOR: 4       # Number of emulators to use
MAX_EVAL_SUBPROCESS: 8   # Max parallel evaluation processes

# ==============================================================================
# Part 4: Agent Model Settings (Adjust as needed)
# ==============================================================================
# Qwen3VL model configuration
QWEN_API_KEY: "YOUR_API_KEY_HERE"  # Replace with your API Key
QWEN_MODEL: "qwen/qwen3-vl-8b-instruct"  # Qwen3-VL-8B-Instruct openrouter


# ==============================================================================
# ==============================================================================
# Below are fixed configurations, generally no modification needed
# ==============================================================================
# ==============================================================================

# ==============================================================================
# Part 5: Mode Presets (Auto-applied based on Part 1 selection)
# ==============================================================================
_MODE_PRESETS:
  environment:
    docker:
      _ADB_PATH: "adb"
      _CONDA_PATH: "/root/miniconda3"
      _EMULATOR_PATH: "/root/.android/emulator/emulator"
      _ANDROID_SDK_PATH: "/root/.android"
      _DEFAULT_KEYBOARD_PACKAGE: "com.google.android.inputmethod.latin/com.android.inputmethod.latin.LatinIME"
      _SYS_AVD_HOME: "/root/.android/avd"
      _SOURCE_AVD_HOME: "/root/.android/avd"
    local:
      _ADB_PATH: "adb"
      _CONDA_PATH: "/home/user/miniconda3"
      _EMULATOR_PATH: "/path/to/android-sdk/emulator/emulator"
      _ANDROID_SDK_PATH: "/path/to/android-sdk"
      _DEFAULT_KEYBOARD_PACKAGE: "com.google.android.inputmethod.latin/com.android.inputmethod.latin.LatinIME"
      _SYS_AVD_HOME: "/path/to/avd"
      _SOURCE_AVD_HOME: "/path/to/avd"

  run:
    _MAX_ATTEMPTS: 3
    _RESULTS_DIR: "./results"
    _SESSION_PREFIX: "memgui-"

# ==============================================================================
# Part 6: Fixed Agent Configuration
# ==============================================================================
MAX_ROUNDS: 0

# AVD configuration
SOURCE_AVD_NAME: "MemGUI-AVD-250704"

# Agent list
AGENTS:
  - NAME: "Qwen3VL"
    REPO_PATH: "./framework/models/AndroidWorld"
    ENV_NAME: "android_world"

# ==============================================================================
# Part 7: MemGUI Evaluator Configuration (Fixed evaluator settings)
# ==============================================================================
# Step description model
MEMGUI_STEP_DESC_MODEL: "google/gemini-2.5-flash"  # google/gemini-2.5-flash
MEMGUI_STEP_DESC_PROVIDER: "openai_compatible"
MEMGUI_STEP_DESC_BASE_URL: null  # null means use BASE_URL

# Final decision model
MEMGUI_FINAL_DECISION_MODEL: "google/gemini-2.5-pro"  # gemini-2.5-pro
MEMGUI_FINAL_DECISION_PROVIDER: "openai_compatible"
MEMGUI_FINAL_DECISION_BASE_URL: null  # null means use BASE_URL

# API configuration
MEMGUI_API_KEY: "YOUR_API_KEY_HERE"  # Replace with your API Key
MEMGUI_MAX_RETRIES: 4
